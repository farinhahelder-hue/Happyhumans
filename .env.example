# ══════════════════════════════════════════════════════
#  Happy Humans — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs
# ══════════════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────────────
# Récupérer sur https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...          # clé publique (anon/public)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...              # clé privée (service_role) — NE PAS exposer !

# ── CMS ADMIN ───────────────────────────────────────────
# Mot de passe pour se connecter à /cms-admin
CMS_PASSWORD=choisir-un-mot-de-passe-fort

# Secret pour signer les cookies de session (optionnel, défaut = CMS_PASSWORD)
CMS_SESSION_SECRET=une-chaine-aleatoire-longue

# ── EMAIL (notifications de réservation) ─────────────────
# Si Monica veut recevoir les demandes de réservation par email
# Utiliser Resend (https://resend.com) ou autre service SMTP
RESEND_API_KEY=re_xxxx                             # optionnel

# ── IA — GROQ ────────────────────────────────────────────
# Génération de contenu dans le CMS — https://console.groq.com
GROQ_API_KEY=gsk_xxxx

# ── IMAGES — UNSPLASH ────────────────────────────────────
# Bibliothèque d'images dans le CMS — https://unsplash.com/developers
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=xxxx
